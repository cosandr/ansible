groups:
- name: Cadvisor
  rules:
  # This rule can be very noisy in dynamic infra with legitimate container start/stop/deployment.
  - alert: ContainerKilled
    expr: time() - container_last_seen{name!=""} > 60
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: '{{ $labels.name }} container on {{ $labels.instance }} dead'

  # This rule can be very noisy in dynamic infra with legitimate container start/stop/deployment.
  - alert: ContainerAbsent
    expr: absent(container_last_seen{name!=""})
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: 'Container {{ $value }} absent on {{ $labels.instance }}'

  - alert: ContainerCpuUsage
    expr: (sum(rate(container_cpu_usage_seconds_total{name!=""}[3m])) BY (instance, name) * 100) > 80
    for: 2m
    labels:
      severity: warning
    annotations:
      summary: '{{ $labels.name }} container on {{ $labels.instance }} CPU usage high: {{ $value }}%'

  # See https://medium.com/faun/how-much-is-too-much-the-linux-oomkiller-and-used-memory-d32186f29c9d
  - alert: ContainerMemoryUsage
    expr: (sum(container_memory_working_set_bytes{name!=""}) BY (instance, name) / sum(container_spec_memory_limit_bytes > 0) BY (instance, name) * 100) > 80
    for: 2m
    labels:
      severity: warning
    annotations:
      summary: '{{ $labels.name }} container on {{ $labels.instance }} memory usage high: {{ $value }}%'

  - alert: ContainerHighThrottleRate
    expr: rate(container_cpu_cfs_throttled_seconds_total{name!=""}[3m]) > 1
    for: 2m
    labels:
      severity: warning
    annotations:
      summary: '{{ $labels.name }} container on {{ $labels.instance }} throttling rate high: {{ $value }}'

  - alert: ContainerUnhealthy
    expr: container_health_state == 0
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: '{{ $labels.name }} container on {{ $labels.instance }} unhealthy'
