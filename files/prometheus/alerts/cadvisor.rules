groups:
- name: Cadvisor
  rules:
  # This rule can be very noisy in dynamic infra with legitimate container start/stop/deployment.
  - alert: ContainerKilled
    expr: time() - container_last_seen{name!=""} > 60
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: '{{ $labels.name }} container on {{ $labels.instance }} dead'

  # Only fires for containers with explicit CPU limits. Containers without limits have cpu_quota=0, which is filtered out by the guard.
  - alert: ContainerHighCPUUtilization
    expr: (sum(rate(container_cpu_usage_seconds_total{name!=""}[5m])) by (instance, name) / sum(container_spec_cpu_quota{name!=""}/container_spec_cpu_period{name!=""}) by (instance, name) * 100) > 80 and sum(container_spec_cpu_quota{name!=""}/container_spec_cpu_period{name!=""}) by (instance, name) > 0
    for: 2m
    labels:
      severity: warning
    annotations:
      summary: '{{ $labels.name }} container on {{ $labels.instance }} high CPU usage: {{ $value | printf "%.2f" }}%'

  # See https://medium.com/faun/how-much-is-too-much-the-linux-oomkiller-and-used-memory-d32186f29c9d
  - alert: ContainerMemoryUsage
    expr: (sum(container_memory_working_set_bytes{name!=""}) BY (instance, name) / sum(container_spec_memory_limit_bytes > 0) BY (instance, name) * 100) > 80
    for: 2m
    labels:
      severity: warning
    annotations:
      summary: '{{ $labels.name }} container on {{ $labels.instance }} memory usage high: {{ $value }}%'

  - alert: ContainerHighThrottleRate
    expr: sum(rate(container_cpu_cfs_throttled_periods_total{name!=""}[5m])) by (instance, name) / sum(rate(container_cpu_cfs_periods_total{name!=""}[5m])) by (instance, name) > 0.25
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: '{{ $labels.name }} container on {{ $labels.instance }} is being throttled {{ $value | humanizePercentage }} '

  - alert: ContainerUnhealthy
    expr: container_health_state == 0
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: '{{ $labels.name }} container on {{ $labels.instance }} unhealthy'

  - alert: ContainerOOMKilled
    expr: increase(container_oom_events_total{name!=""}[5m]) > 0
    for: 1m
    labels:
      severity: critical
    annotations:
      summary: "{{ $labels.name }} container on {{ $labels.instance }} got OOM killed"

  - alert: ContainerRestartLoop
    expr: increase(container_start_time_seconds{name!=""}[15m]) > 3
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: '{{ $labels.name }} container on {{ $labels.instance }} is crash looping'

  - alert: ContainerHighDiskWrite
    expr: sum(rate(container_fs_writes_bytes_total{name!=""}[5m])) BY (instance, name) > 50000000 # 50 MB/s
    for: 3m
    labels:
      severity: warning
    annotations:
      summary: '{{ $labels.name }} container on {{ $labels.instance }} has high disk write throughput'
